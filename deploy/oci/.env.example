# Compose and deployment script configuration. Copy outside the repository,
# for example to /etc/habitflow/oci.env, then replace every placeholder.
DOMAIN=your-domain.example
LETSENCRYPT_EMAIL=admin@your-domain.example
PUBLIC_IPV4=203.0.113.10
CERTBOT_STAGING=false

VITE_API_URL=/api/v1

POSTGRES_DATA_DIR=/srv/habitflow/postgres-data
BACKUP_DIR=/srv/habitflow/backups
CERTBOT_CONF_DIR=/srv/habitflow/certbot/conf
CERTBOT_WWW_DIR=/srv/habitflow/certbot/www
NGINX_LOG_DIR=/srv/habitflow/nginx-logs

BACKEND_ENV_FILE=/etc/habitflow/backend.env
POSTGRES_ENV_FILE=/etc/habitflow/postgres.env
POSTGRES_DB=habitflow
POSTGRES_USER=habitflow
BACKUP_RETENTION_DAYS=7

# Leave both values empty to keep backups on the VM only. When both are set,
# backup-postgres.sh uploads verified dumps through the OCI CLI.
OCI_OBJECT_STORAGE_NAMESPACE=
OCI_OBJECT_STORAGE_BUCKET=
