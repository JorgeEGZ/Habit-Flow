# Backend container values. Keep the deployed file outside the repository.
DATABASE_URL=postgresql+asyncpg://habitflow:REPLACE_WITH_POSTGRES_PASSWORD@postgres:5432/habitflow
SECRET_KEY=REPLACE_WITH_A_RANDOM_SECRET_OF_AT_LEAST_32_BYTES
ENVIRONMENT=production
DEBUG=false
APP_TIMEZONE=America/Bogota
CORS_ORIGINS=["https://your-domain.example"]
REFRESH_COOKIE_SECURE=true
REFRESH_COOKIE_SAMESITE=lax
REFRESH_COOKIE_PATH=/api/v1/auth
CSRF_HEADER_NAME=X-CSRF-Protection
CSRF_HEADER_VALUE=1
MIGRATE_ON_START=false
PORT=8000
