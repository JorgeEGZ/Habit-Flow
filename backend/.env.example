# Use this value only when FastAPI runs directly on the host.
# Docker Compose injects postgres:5432 for the backend container.
DATABASE_URL=postgresql+asyncpg://habitflow:habitflow@localhost:5433/habitflow
SECRET_KEY=change_this_later
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
ENVIRONMENT=development
DEBUG=false
APP_TIMEZONE=America/Bogota
CORS_ORIGINS=["http://localhost:5173"]
REFRESH_COOKIE_NAME=habitflow_refresh
REFRESH_COOKIE_SECURE=false
REFRESH_COOKIE_SAMESITE=lax
REFRESH_COOKIE_PATH=/api/v1/auth
CSRF_HEADER_NAME=X-CSRF-Protection
CSRF_HEADER_VALUE=1
